// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  password      String?
  role          String   @default("USER")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Goldprint Gate System
  goldprintQuota        Int      @default(0)
  goldprintQuotaResetAt DateTime?
  totalBlueprintsPurchased Int @default(0)
  maxGoldprintsAllowed  Int      @default(40)

  blueprints         Blueprint[]
  auditSubmissions   AuditSubmission[]
  subscription       Subscription?
  payments           Payment[]
  tierChangeQuotes   TierChangeQuote[]
  passwordResetTokens PasswordResetToken[]
  goldprintRequests  GoldprintRequest[]
  goldprints         Goldprint[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blueprint {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  idea            String
  status          String   @default("PENDING")
  content         String?
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?
  paymentRequired Boolean  @default(true)
  paymentId       String?  @unique
  payment         Payment?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditSubmission {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email         String
  plan          String
  result        String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AIConfig {
  id            String   @id @default(cuid())
  key           String   @unique
  value         String
  provider      String?  @default("groq")
  updatedAt     DateTime @updatedAt
}

model PaymentTier {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique

  // Legacy fields (kept for migration compatibility)
  price         Decimal?
  currency      String?

  // Payment Options: Budget | One Payment | Tiered
  budgetPrice       Decimal?
  onePaymentPrice   Decimal?
  tieredBasePrice   Decimal?
  tieredMaxPrice    Decimal?

  // Currency Support
  baseCurrency      String   @default("ZAR")
  supportedCurrencies String @default("[\"ZAR\",\"USD\",\"EUR\",\"GBP\"]")

  maxBlueprints Int      @default(1)
  features      String   @default("[]")
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  subscriptions         Subscription[]
  requestedTierQuotes   TierChangeQuote[] @relation("RequestedTier")
  currentTierQuotes     TierChangeQuote[] @relation("CurrentTier")
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tierId        String?
  tier          PaymentTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  status        String   @default("NONE")
  startedAt     DateTime @default(now())
  expiresAt     DateTime?
  payfastToken  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blueprintId   String?  @unique
  blueprint     Blueprint? @relation(fields: [blueprintId], references: [id], onDelete: SetNull)

  // Payment Options
  selectedOption String  @default("ONE_PAYMENT")
  amount        Decimal
  originalAmount Decimal?
  currency      String   @default("ZAR")
  exchangeRate  Decimal  @default(1)

  method        String   @default("PAYFAST")
  status        String   @default("PENDING")
  reference     String?
  payfastToken  String?
  description   String?

  // Unlocks goldprint gate
  unlocksGoldprints Boolean @default(false)
  goldprintsUnlocked Int    @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ===== GOLDPRINT SYSTEM =====

model GoldprintRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String   @db.Text
  status      String   @default("PENDING")

  // AI Engine Decision
  aiDecision  String?
  aiReasoning String?  @db.Text
  aiReviewedAt DateTime?

  // Auction Queue
  isAuctionEligible Boolean @default(false)
  isForAuction    Boolean @default(false)
  auctionListedAt DateTime?

  adminNotes  String?  @db.Text
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([isAuctionEligible])
}

model Goldprint {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  content     String   @db.Text
  source      String   @default("APPROVED")
  auctionId   String?

  // Dashboard Display Only
  isReady     Boolean  @default(false)
  readyAt     DateTime?
  viewedAt    DateTime?

  // Automation
  deliveryMethod   String   @default("IMMEDIATE")
  scheduledReadyAt DateTime?
  bulkGroupId     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([isReady])
  @@index([scheduledReadyAt])
}

// ===== AUCTION MODELS =====

model Auction {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  status      String   @default("SCHEDULED")
  startTime   DateTime?
  endTime     DateTime?
  startingBid Decimal  @default(0)
  bidIncrement Decimal @default(10)
  winnerId    String?
  winningBid  Decimal?

  // Admin Controls
  createdBy   String?
  alertTimingMinutes Int @default(10)
  customAlertMessage String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bids        Bid[]
  greyprint   Greyprint?
  @@index([status])
  @@index([startTime])
}

model Bid {
  id          String   @id @default(cuid())
  auctionId   String
  auction     Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  userId      String
  amount      Decimal
  createdAt   DateTime @default(now())

  @@index([auctionId])
  @@index([userId])
}

model Greyprint {
  id          String   @id @default(cuid())
  auctionId   String   @unique
  auction     Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  reason      String   @default("NO_SHOW")
  details     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [email], references: [email], onDelete: Cascade)
  
  @@index([email])
  @@index([token])
}

model AgentPrompt {
  id           String   @id @default(cuid())
  agentName    String
  description  String?
  systemPrompt String
  isActive     Boolean  @default(true)
  tools        String   @default("[]")
  modelConfig  String   @default("{}")
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TierChangeQuote {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  requestedTierId String
  requestedTier   PaymentTier  @relation("RequestedTier", fields: [requestedTierId], references: [id], onDelete: Restrict)

  currentTierId  String?
  currentTier    PaymentTier? @relation("CurrentTier", fields: [currentTierId], references: [id], onDelete: SetNull)

  status         String   @default("PENDING") // PENDING | QUOTED | APPROVED | DENIED
  quoteAmount    Decimal?
  currency       String   @default("ZAR")

  decidedBy      String?
  decidedAt      DateTime?

  denialReason   String?
  denialFeedback String?  @default("{}") // JSON string of questionnaire responses

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}
